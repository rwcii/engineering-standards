#!/bin/sh
# Per WDR 010 (Branch & Merge Flow): 'main' never receives direct commits — only
# merge commits promoted from 'develop'. This guard blocks a non-merge commit while
# on 'main'; merge commits (a MERGE_HEAD is present) are allowed, so promoting
# 'develop' into 'main' still works.
#
# Enable once per clone:  git config core.hooksPath .githooks

branch="$(git symbolic-ref --short -q HEAD)"
git_dir="$(git rev-parse --git-dir)"

if [ "$branch" = "main" ] && [ ! -f "$git_dir/MERGE_HEAD" ]; then
  echo "Blocked: direct commits to 'main' are not allowed (WDR 010)." >&2
  echo "  Work on a feature branch off 'develop'; squash-merge to 'develop'," >&2
  echo "  then promote 'develop' to 'main' with a merge commit." >&2
  exit 1
fi

exit 0
